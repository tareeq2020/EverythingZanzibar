{
  "name": "everything-zanzibar",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Everything Zanzibar — static luxury travel site with Supabase-backed SSG pre-render and a compiled Tailwind build.",
  "scripts": {
    "build:css": "tailwindcss -i ./assets/css/input.css -o ./assets/css/app.min.css --minify",
    "build:ssg": "node --env-file=.env scripts/build-ssg.mjs",
    "build": "npm run build:css && npm run build:ssg",
    "dev:css": "tailwindcss -i ./assets/css/input.css -o ./assets/css/app.min.css --watch"
  },
  "engines": { "node": ">=20.6.0" },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.13"
  }
}
